@page
@model ContentCms.API.Pages.AuditLogModel
@{
    ViewData["Title"] = "Audit Log";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Audit Log</h1>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Content Path</th>
                <th scope="col">Action</th>
                <th scope="col">Timestamp (UTC)</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Logs.Any())
            {
                foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.Id</td>
                        <td>@(log.Content != null ? log.Content.Path : "N/A (Deleted/Missing)")</td>
                        <td>
                            <span class="badge bg-secondary">
                                @Model.GetReadableActionType(log.ActionType)
                            </span>
                        </td>
                        <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">No audit logs found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-page="/AuditLog" asp-route-pageNumber="@(Model.CurrentPage - 1)">Previous</a>
            </li>
            
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-page="/AuditLog" asp-route-pageNumber="@i">@i</a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-page="/AuditLog" asp-route-pageNumber="@(Model.CurrentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

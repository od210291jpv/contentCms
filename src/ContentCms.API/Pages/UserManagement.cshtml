@page
@model ContentCms.API.Pages.UserManagementModel
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">User Management</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <span class="badge bg-secondary fs-6">
            <i class="bi bi-people me-1"></i> Admin View
        </span>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Role</th>
                <th>Is Active</th>
                <th>Is Deleted</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>
                        <a href="/UserProfile?id=@user.Id" class="text-decoration-none fw-semibold">
                            <i class="bi bi-person me-1"></i>@user.Username
                        </a>
                    </td>
                    <td>
                        @if (user.Role == ContentCms.API.Models.UserRole.Admin)
                        {
                            <span class="badge bg-warning text-dark">Admin</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">User</span>
                        }
                    </td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>
                    <td>
                        @if (user.IsDeleted)
                        {
                            <span class="badge bg-danger">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">No</span>
                        }
                    </td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu shadow">
                                <li>
                                    <a class="dropdown-item change-username-btn" href="#"
                                       data-bs-toggle="modal" data-bs-target="#changeUsernameModal"
                                       data-user-id="@user.Id"
                                       data-username="@user.Username">
                                        <i class="bi bi-pencil me-1"></i> Change Username
                                    </a>
                                </li>
                                <li>
                                    <form method="post" asp-page-handler="ToggleActivation">
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <input type="hidden" name="isActive" value="@user.IsActive.ToString().ToLower()" />
                                        <button type="submit" class="dropdown-item">
                                            @if (user.IsActive)
                                            {
                                                <i class="bi bi-pause-circle me-1"></i>
                                                <text>Deactivate</text>
                                            }
                                            else
                                            {
                                                <i class="bi bi-play-circle me-1"></i>
                                                <text>Activate</text>
                                            }
                                        </button>
                                    </form>
                                </li>
                                <li>
                                    <a class="dropdown-item set-password-btn" href="#"
                                       data-bs-toggle="modal" data-bs-target="#setPasswordModal"
                                       data-user-id="@user.Id"
                                       data-username="@user.Username">
                                        <i class="bi bi-key me-1"></i> Set Password
                                    </a>
                                </li>
                                @if (!user.IsDeleted)
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page-handler="SoftDelete">
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="dropdown-item text-danger"
                                                    onclick="return confirm('Are you sure you want to soft delete user @user.Username?');">
                                                <i class="bi bi-trash me-1"></i> Soft Delete
                                            </button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Users.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">No users found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-route-pageNumber="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

<!-- Change Username Modal -->
<div class="modal fade" id="changeUsernameModal" tabindex="-1" aria-labelledby="changeUsernameModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="ChangeUsername">
                <div class="modal-header">
                    <h5 class="modal-title" id="changeUsernameModalLabel">
                        <i class="bi bi-pencil me-2"></i>Change Username
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="changeUsernameUserId" name="id" />
                    <div class="mb-3">
                        <label for="changeUsernameValue" class="form-label">New Username</label>
                        <input type="text" class="form-control" id="changeUsernameValue"
                               name="username" maxlength="100" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Set Password Modal -->
<div class="modal fade" id="setPasswordModal" tabindex="-1" aria-labelledby="setPasswordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="SetPassword">
                <div class="modal-header">
                    <h5 class="modal-title" id="setPasswordModalLabel">
                        <i class="bi bi-key me-2"></i>Set Password
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="setPasswordUserId" name="id" />
                    <p class="text-muted small">Setting password for: <strong id="setPasswordUsername"></strong></p>
                    <div class="mb-3">
                        <label for="setPasswordValue" class="form-label">New Password</label>
                        <input type="password" class="form-control" id="setPasswordValue"
                               name="password" minlength="1" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Set Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Change Username Modal
            const changeUsernameModal = document.getElementById('changeUsernameModal');
            if (changeUsernameModal) {
                changeUsernameModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    document.getElementById('changeUsernameUserId').value = btn.getAttribute('data-user-id');
                    document.getElementById('changeUsernameValue').value = btn.getAttribute('data-username');
                });
            }

            // Set Password Modal
            const setPasswordModal = document.getElementById('setPasswordModal');
            if (setPasswordModal) {
                setPasswordModal.addEventListener('show.bs.modal', function (event) {
                    const btn = event.relatedTarget;
                    document.getElementById('setPasswordUserId').value = btn.getAttribute('data-user-id');
                    document.getElementById('setPasswordUsername').textContent = btn.getAttribute('data-username');
                    document.getElementById('setPasswordValue').value = '';
                });
            }
        });
    </script>
}

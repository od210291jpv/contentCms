@page
@model ContentCms.API.Pages.ContentManagementModel
@{
    ViewData["Title"] = "Content Management";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Content Management</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
            <i class="bi bi-cloud-upload"></i> Upload Content
        </button>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Owner ID</th>
                <th>Enabled</th>
                <th>Description</th>
                <th>Image</th>
                <th>Is Public</th>
                <th>Is Deleted</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th>Deleted At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Contents)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><a href="#" class="text-decoration-none">@item.OwnerId (@item.Owner?.Username)</a></td>
                    <td>
                        @if (item.Enabled)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">No</span>
                        }
                    </td>
                    <td title="@item.Description">
                        @(string.IsNullOrEmpty(item.Description) ? "" : (item.Description.Length > 20 ? item.Description.Substring(0, 20) + "..." : item.Description))
                    </td>
                    <td>
                        <button type="button" class="btn btn-sm btn-outline-info preview-btn" data-img-url="@item.Path" data-bs-toggle="modal" data-bs-target="#previewModal">
                            <i class="bi bi-image"></i> Preview
                        </button>
                    </td>
                    <td>
                        @if (item.IsPublic)
                        {
                            <span class="badge bg-info">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>
                        @if (item.IsDeleted)
                        {
                            <span class="badge bg-danger">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-light text-dark">No</span>
                        }
                    </td>
                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(item.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td>@(item.DeletedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Actions
                            </button>
                            <ul class="dropdown-menu shadow">
                                @if (Model.IsAdmin)
                                {
                                    <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#reassignModal" data-content-id="@item.Id" data-owner-id="@item.OwnerId"><i class="bi bi-person-gear"></i> Re-assign</a></li>
                                }
                                <li>
                                    <form method="post" asp-page-handler="ToggleStatus">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="enabled" value="@(item.Enabled ? "false" : "true")" />
                                        <button type="submit" class="dropdown-item"><i class="bi bi-power"></i> @(item.Enabled ? "Disable" : "Enable")</button>
                                    </form>
                                </li>
                                <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#editDescModal" data-content-id="@item.Id" data-desc="@item.Description"><i class="bi bi-pencil"></i> Edit Description</a></li>
                                <li>
                                    <form method="post" asp-page-handler="ToggleVisibility">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="isPublic" value="@(item.IsPublic ? "false" : "true")" />
                                        <button type="submit" class="dropdown-item"><i class="bi bi-eye"></i> @(item.IsPublic ? "Make Private" : "Make Public")</button>
                                    </form>
                                </li>
                                @if (!item.IsDeleted)
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page-handler="SoftDelete">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Are you sure you want to soft delete this content?');"><i class="bi bi-trash"></i> Soft Delete</button>
                                        </form>
                                    </li>
                                }
                            </ul>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Contents.Any())
            {
                <tr>
                    <td colspan="11" class="text-center py-4 text-muted">No content available.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-route-pageNumber="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-route-pageNumber="@(Model.CurrentPage + 1)">Next</a>
            </li>
        </ul>
    </nav>
}

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Upload" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="uploadModalLabel">Upload Content</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="file" class="form-label">Select File</label>
                        <input class="form-control" type="file" id="file" name="file" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea class="form-control" id="description" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="isPublic" name="isPublic" value="true">
                        <label class="form-check-label" for="isPublic">
                            Make Public
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="previewModalLabel">Image Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center bg-light">
                <img id="previewImage" src="" alt="Preview" class="img-fluid rounded" style="max-height: 70vh;" />
            </div>
        </div>
    </div>
</div>

<!-- Edit Description Modal -->
<div class="modal fade" id="editDescModal" tabindex="-1" aria-labelledby="editDescModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="UpdateDescription">
                <div class="modal-header">
                    <h5 class="modal-title" id="editDescModalLabel">Edit Description</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editDescId" name="id" />
                    <div class="mb-3">
                        <label for="editDescriptionText" class="form-label">Description</label>
                        <textarea class="form-control" id="editDescriptionText" name="description" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Re-assign Modal (Admin Only) -->
@if (Model.IsAdmin)
{
    <div class="modal fade" id="reassignModal" tabindex="-1" aria-labelledby="reassignModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-page-handler="Reassign">
                    <div class="modal-header">
                        <h5 class="modal-title" id="reassignModalLabel">Re-assign Content</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="hidden" id="reassignContentId" name="id" />
                        <div class="mb-3">
                            <label for="newOwnerId" class="form-label">New Owner ID</label>
                            <input type="number" class="form-control" id="newOwnerId" name="newOwnerId" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Re-assign</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Preview Modal Logic
            const previewModal = document.getElementById('previewModal');
            if (previewModal) {
                previewModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    const imgUrl = button.getAttribute('data-img-url');
                    const previewImage = document.getElementById('previewImage');
                    previewImage.src = imgUrl;
                });
            }

            // Edit Description Modal Logic
            const editDescModal = document.getElementById('editDescModal');
            if (editDescModal) {
                editDescModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    const contentId = button.getAttribute('data-content-id');
                    const desc = button.getAttribute('data-desc');
                    document.getElementById('editDescId').value = contentId;
                    document.getElementById('editDescriptionText').value = desc;
                });
            }

            // Re-assign Modal Logic
            const reassignModal = document.getElementById('reassignModal');
            if (reassignModal) {
                reassignModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    const contentId = button.getAttribute('data-content-id');
                    const ownerId = button.getAttribute('data-owner-id');
                    document.getElementById('reassignContentId').value = contentId;
                    document.getElementById('newOwnerId').value = ownerId;
                });
            }
        });
    </script>
}
